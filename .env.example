# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://hdv:hdv@localhost:5433/hdv?schema=public

# Auth.js
ENABLE_EMAIL_AUTH=false
NEXT_PUBLIC_ENABLE_EMAIL_AUTH=false
AUTH_SECRET=replace-with-random-long-secret
AUTH_URL=http://localhost:3000
EMAIL_FROM="HDV <no-reply@hdv.local>"
# SMTP (for magic link)
EMAIL_SERVER_HOST=localhost
EMAIL_SERVER_PORT=1025
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=

# Optional Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Ledger
LEDGER_KEY_ID=hdv-local-ed25519
# Optional: provide your own PEM keys
LEDGER_PRIVATE_KEY_PEM=
LEDGER_PUBLIC_KEY_PEM=
LEDGER_BATCH_SIZE=5

# Storage
STORAGE_PROVIDER=local
S3_BUCKET=hdv-mvp
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# E2E
E2E_BASE_URL=http://localhost:3000
