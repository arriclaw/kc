generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  DEALER
  ADMIN
}

enum DealerVerifiedStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum OwnershipStatus {
  CURRENT
  PAST
}

enum EventType {
  ODOMETER
  SERVICE
  REPAIR
  ACCIDENT
  INSPECTION
  OTHER
  CORRECTION
}

enum SourceKind {
  SELF_DECLARED
  DEALER_ENTERED
  THIRD_PARTY
}

enum VerificationStatus {
  UNVERIFIED
  VERIFIED
}

enum ShareVisibility {
  PUBLIC_SUMMARY
  FULL_HISTORY
}

enum BadgeType {
  TRANSPARENT_OWNER
  MAINTENANCE_STREAK
  RECENT_SERVICE
  LOW_RISK
}

enum ContactRequesterType {
  PARTICULAR
  AUTOMOTORA
  COMPRADOR
  OTRO
}

enum ContactMessageStatus {
  NEW
  REVIEWED
  CLOSED
}

model User {
  id            String             @id @default(uuid())
  email         String             @unique
  passwordHash  String?
  phone         String?
  whatsapp      String?
  contactEmail  String?
  name          String?
  role          Role               @default(OWNER)
  createdAt     DateTime           @default(now())
  dealerProfile DealerProfile?
  ownerships    VehicleOwnership[]
  events        Event[]            @relation("EventCreatedBy")
  accounts      Account[]
  sessions      Session[]
}

model DealerProfile {
  id             String               @id @default(uuid())
  userId         String               @unique
  dealerName     String
  legalName      String?
  phone          String?
  location       String?
  verifiedStatus DealerVerifiedStatus @default(PENDING)
  createdAt      DateTime             @default(now())
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Vehicle {
  id          String              @id @default(uuid())
  vin         String?
  plate       String?
  country     String              @default("UY")
  make        String
  model       String
  year        Int
  createdAt   DateTime            @default(now())
  ownerships  VehicleOwnership[]
  events      Event[]
  badges      Badge[]
  shareLinks  VehicleAccessLink[]
  flags       Flag[]

  @@index([plate])
  @@index([vin])
}

model VehicleOwnership {
  id              String          @id @default(uuid())
  vehicleId       String
  userId          String
  ownershipStatus OwnershipStatus @default(CURRENT)
  startedAt       DateTime
  endedAt         DateTime?
  vehicle         Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([vehicleId, ownershipStatus])
}

model VehicleAccessLink {
  id         String          @id @default(uuid())
  vehicleId  String
  token      String          @unique
  visibility ShareVisibility @default(PUBLIC_SUMMARY)
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdAt  DateTime        @default(now())
  vehicle    Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model Event {
  id                  String             @id @default(uuid())
  vehicleId           String
  type                EventType
  occurredAt          DateTime
  odometerKm          Int?
  title               String
  description         String
  cost                Decimal?           @db.Decimal(10, 2)
  location            String?
  createdByUserId     String
  sourceKind          SourceKind         @default(SELF_DECLARED)
  verificationStatus  VerificationStatus @default(UNVERIFIED)
  needsClarification  Boolean            @default(false)
  correctionOfEventId String?
  createdAt           DateTime           @default(now())
  vehicle             Vehicle            @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  createdBy           User               @relation("EventCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  correctionOfEvent   Event?             @relation("EventCorrection", fields: [correctionOfEventId], references: [id])
  corrections         Event[]            @relation("EventCorrection")
  attachments         Attachment[]
  ledgerEntry         LedgerEntry?

  @@index([vehicleId, occurredAt])
}

model Attachment {
  id        String   @id @default(uuid())
  eventId   String
  url       String
  mimeType  String
  fileName  String
  size      Int
  sha256    String
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model Badge {
  id        String   @id @default(uuid())
  vehicleId String
  badgeType BadgeType
  awardedAt DateTime @default(now())
  metadata  Json?
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([vehicleId, badgeType])
}

model LedgerEntry {
  id              String   @id @default(uuid())
  entityType      String
  entityId        String   @unique
  payloadHash     String
  prevHash        String
  entryHash       String   @unique
  merkleRootBatchId String?
  signature       String?
  signedByKeyId   String?
  createdAt       DateTime @default(now())
  batch           LedgerBatch? @relation(fields: [merkleRootBatchId], references: [id])
  event           Event?    @relation(fields: [entityId], references: [id], onDelete: Cascade)
}

model LedgerBatch {
  id          String        @id @default(uuid())
  merkleRoot  String
  entriesCount Int
  anchoredAt  DateTime?
  anchorRef   String?
  createdAt   DateTime      @default(now())
  entries     LedgerEntry[]
}

model Flag {
  id          String   @id @default(uuid())
  vehicleId   String
  eventId     String?
  reason      String
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model ContactMessage {
  id            String               @id @default(uuid())
  name          String
  email         String
  phone         String?
  requesterType ContactRequesterType @default(OTRO)
  subject       String
  message       String
  status        ContactMessageStatus @default(NEW)
  createdAt     DateTime             @default(now())
  reviewedAt    DateTime?

  @@index([status, createdAt])
  @@index([email])
}
